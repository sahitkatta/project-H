# Copy to .env — do not commit .env
#
# Docker / IPv4: the direct host db.<project>.supabase.co is often IPv6-only → "Network is unreachable".
# Use the Session pooler URI from Supabase: Project → Connect → Session pooler.
#
# Username is: postgres.<project_ref>
# Host is like: aws-0-<region> or aws-1-<region> — copy exactly from the dashboard (region must match).
#
DATABASE_URL=postgresql://postgres.hgstmxtefpjtncanqcnm:YOUR_DB_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require
