# Build static assets only. Tag this image, then build the app image (see build.sh).
FROM node:20-alpine AS builder
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# Lightweight carrier image so the app Dockerfile can COPY --from=<tag> /dist
FROM alpine:3.20
COPY --from=builder /app/dist /dist
